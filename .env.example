# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI provider chain (all optional - leave blank to skip a provider)
# 1. Gemini (free tier ~14,400 req/day)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# 2. Groq (free, fast inference)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# 3. Local Ollama (no cost, no key)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# 4. Anthropic Claude (optional, paid)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Order of providers to try, comma separated. First that works wins.
AI_PROVIDER_CHAIN=gemini,groq,ollama,claude
